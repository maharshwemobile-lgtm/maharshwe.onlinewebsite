<!DOCTYPE html>
<html lang="my">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>Repair Solution - Mahar Shwe Mobile</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Noto+Sans+Myanmar:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Inter', 'Noto Sans Myanmar', sans-serif; background: #f6f7fb; color: #111827; }
    .glass { background: rgba(255, 255, 255, 0.86); backdrop-filter: blur(18px); }
  </style>
</head>
<body>
  <header class="sticky top-0 z-50 border-b border-slate-200 glass">
    <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-3">
      <a href="/" class="flex items-center gap-3">
        <img src="/logo.jpg" alt="Mahar Shwe Mobile" class="h-11 w-11 rounded-xl object-cover ring-1 ring-slate-200">
        <span>
          <span class="block text-base font-extrabold text-slate-950">Mahar Shwe Mobile</span>
          <span class="block text-xs font-semibold text-slate-500">Repair Solution</span>
        </span>
      </a>
      <a href="/#home" class="rounded-xl border border-slate-200 bg-white px-4 py-2 text-sm font-extrabold text-slate-800">Home</a>
    </div>
  </header>

  <main class="mx-auto max-w-6xl px-4 py-8">
    <section class="rounded-2xl bg-slate-950 p-6 text-white sm:p-8">
      <p class="text-sm font-bold uppercase tracking-wide text-amber-300">Repair Solution Library</p>
      <h1 class="mt-3 max-w-3xl text-4xl font-extrabold leading-tight">á€–á€¯á€”á€ºá€¸á€•á€¼á€„á€ºá€”á€Šá€ºá€¸á€”á€¾á€„á€ºá€· Error Solution á€™á€»á€¬á€¸</h1>
      <p class="mt-4 max-w-3xl leading-8 text-slate-200">Software, Hardware, Network, Battery, Display, Unlock á€…á€á€²á€· solution á€™á€»á€¬á€¸á€€á€­á€¯ á€¡á€™á€¼á€”á€ºá€›á€¾á€¬á€–á€½á€±á€–á€á€ºá€›á€¾á€¯á€”á€­á€¯á€„á€ºá€•á€«á€á€šá€ºá‹</p>
      <div class="mt-6 max-w-2xl">
        <input id="searchInput" class="w-full rounded-xl border border-white/10 bg-white px-4 py-3 text-slate-950 outline-none focus:ring-4 focus:ring-amber-400/20" placeholder="Search repair solution">
      </div>
    </section>

    <section class="mt-6">
      <div class="mb-4 flex items-center justify-between gap-3">
        <h2 class="text-xl font-extrabold text-slate-950">Latest Solutions</h2>
        <span id="resultCount" class="rounded-full bg-white px-3 py-1 text-xs font-bold text-slate-500 ring-1 ring-slate-200">0 items</span>
      </div>
      <div id="solutionsFeed" class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
        <div class="rounded-2xl bg-white p-6 text-sm font-bold text-slate-500 shadow-sm ring-1 ring-slate-200">Loading solutions...</div>
      </div>
    </section>
  </main>

  <footer class="mt-8 border-t border-slate-200 bg-white">
    <div class="mx-auto flex max-w-6xl flex-col gap-3 px-4 py-6 text-sm text-slate-600 sm:flex-row sm:items-center sm:justify-between">
      <p class="font-semibold">Contact: 09778394052</p>
      <a class="font-bold text-slate-950" href="https://t.me/Mylifemychoice68" target="_blank" rel="noreferrer">Telegram: @Mylifemychoice68</a>
    </div>
  </footer>

  <script>
    const API_BASE = '/api';
    const fallbackSolutions = [
      { id: 1, title: 'iPhone Battery Drain Fix', description: 'Battery calibration, background app check á€”á€¾á€„á€ºá€· charging port á€…á€…á€ºá€†á€±á€¸á€”á€Šá€ºá€¸á‹', category: 'Software', author: 'Admin', date: '2026-05-16', likes: 8 },
      { id: 2, title: 'Samsung Screen Touch Error', description: 'Touch IC, display connector á€”á€¾á€„á€ºá€· software test á€¡á€†á€„á€ºá€·á€™á€»á€¬á€¸á‹', category: 'Hardware', author: 'Technician', date: '2026-05-16', likes: 5 },
      { id: 3, title: 'Android Network Error', description: 'APN, SIM tray, baseband status á€”á€¾á€„á€ºá€· reset method á€™á€»á€¬á€¸á‹', category: 'Network', author: 'Admin', date: '2026-05-16', likes: 3 }
    ];

    function el(id) { return document.getElementById(id); }
    function escapeHtml(value) {
      return String(value || '').replace(/[&<>"']/g, char => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[char]));
    }
    async function fetchSolutions() {
      const q = (el('searchInput').value || '').trim();
      let solutions = fallbackSolutions;
      try {
        const res = await fetch(API_BASE + '/solutions' + (q ? '?q=' + encodeURIComponent(q) : ''));
        if (!res.ok) throw new Error('HTTP ' + res.status);
        const data = await res.json();
        if (Array.isArray(data) && data.length) solutions = data;
      } catch (e) {}

      if (q) {
        const lower = q.toLowerCase();
        solutions = solutions.filter(item => (item.title + ' ' + item.description + ' ' + item.category).toLowerCase().includes(lower));
      }

      el('resultCount').textContent = solutions.length + ' items';
      el('solutionsFeed').innerHTML = solutions.length ? solutions.map(item =>
        '<article class="rounded-2xl bg-white p-5 shadow-sm ring-1 ring-slate-200">' +
          '<div class="flex items-center justify-between gap-3">' +
            '<span class="rounded-full bg-amber-100 px-3 py-1 text-xs font-extrabold text-amber-800">' + escapeHtml(item.category || 'Tips') + '</span>' +
            '<span class="text-xs font-bold text-slate-400">' + escapeHtml(item.date || '') + '</span>' +
          '</div>' +
          (item.image ? '<img src="' + escapeHtml(item.image) + '" alt="' + escapeHtml(item.title) + '" class="mt-4 aspect-video w-full rounded-xl object-cover ring-1 ring-slate-200">' : '') +
          '<h3 class="mt-4 text-lg font-extrabold leading-7 text-slate-950">' + escapeHtml(item.title) + '</h3>' +
          '<p class="mt-3 text-sm leading-7 text-slate-600">' + escapeHtml(item.description) + '</p>' +
          '<div class="mt-5 flex items-center justify-between border-t border-slate-100 pt-4 text-xs font-bold text-slate-500">' +
            '<span>' + escapeHtml(item.author || 'Admin') + '</span>' +
            '<button class="rounded-lg bg-slate-100 px-3 py-1 text-slate-700" onclick="likeSolution(' + Number(item.id) + ')">' + Number(item.likes || 0) + ' likes</button>' +
          '</div>' +
        '</article>'
      ).join('') : '<div class="rounded-2xl bg-white p-8 text-center font-bold text-slate-500 shadow-sm ring-1 ring-slate-200 md:col-span-2 xl:col-span-3">No solution found.</div>';
    }

    async function likeSolution(id) {
      try {
        await fetch(API_BASE + '/solutions/' + id + '/like', { method: 'PUT' });
        await fetchSolutions();
      } catch (e) {}
    }
    el('searchInput').addEventListener('input', function() {
      clearTimeout(window.searchTimer);
      window.searchTimer = setTimeout(fetchSolutions, 250);
    });
    fetchSolutions();
  </script>
</body>
</html>

