<!DOCTYPE html>
<html lang="my">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>Mahar Shwe Mobile</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&family=Noto+Sans+Myanmar:wght@400;600;700;800&display=swap" rel="stylesheet">
  <style>
    body { margin:0; font-family: Inter, 'Noto Sans Myanmar', sans-serif; background:#f7f8fb; color:#0f172a; }
    .page { display:none; }
    .page.active { display:block; }
    .nav.active { background:#0f766e; color:white; }
    .bottom { padding-bottom: max(12px, env(safe-area-inset-bottom)); }
  </style>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Myanmar:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>body{font-family:"Noto Sans Myanmar",Arial,sans-serif!important;}</style>
</head>
<body>
  <header class="sticky top-0 z-50 border-b border-slate-200 bg-white/95 backdrop-blur">
    <div class="mx-auto flex max-w-6xl items-center justify-between gap-3 px-4 py-3">
      <button class="flex items-center gap-3 text-left" data-page="home">
        <img src="logo.jpg" alt="Mahar Shwe Mobile" class="h-11 w-11 rounded-2xl object-cover ring-1 ring-slate-200">
        <span><b class="block text-slate-950">Mahar Shwe Mobile</b><small class="font-bold text-slate-500">Phone Repair & Digital Service</small></span>
      </button>
      <a class="rounded-2xl bg-slate-950 px-4 py-2 text-sm font-black text-white" href="tel:09778394052">Call</a>
    </div>
  </header>

  <main class="mx-auto max-w-6xl px-4 py-4 pb-28">
    <section id="homePage" class="page active">
      <div class="rounded-[28px] bg-slate-950 p-5 text-white shadow-xl">
        <p class="text-xs font-black uppercase text-teal-200">Online Service</p>
        <h1 class="mt-3 text-4xl font-black leading-tight">Mahar Shwe Mobile Service Center</h1>
        <p class="mt-4 text-sm leading-7 text-slate-200">Voucher နံပါတ်ဖြင့် ဖုန်းပြင်ဆင်မှုအခြေအနေ စစ်နိုင်ပြီး Repair Solution, Digital Product နှင့် ငွေလဲနှုန်းများကို ကြည့်နိုင်ပါတယ်။</p>
        <div class="mt-6 grid grid-cols-2 gap-3">
          <button class="rounded-2xl bg-amber-400 px-4 py-3 text-sm font-black text-slate-950" data-page="voucher">Voucher စစ်ရန်</button>
          <button class="rounded-2xl bg-white/10 px-4 py-3 text-sm font-black text-white ring-1 ring-white/20" data-page="products">Products</button>
        </div>
      </div>
      <div class="mt-4 grid grid-cols-2 gap-3">
        <button class="rounded-3xl bg-white p-4 text-left shadow-sm ring-1 ring-slate-200" data-page="solutions"><b>Repair Solution</b><p class="mt-2 text-xs text-slate-600">ဖုန်းပြင်နည်းများ</p></button>
        <button class="rounded-3xl bg-white p-4 text-left shadow-sm ring-1 ring-slate-200" data-page="currency"><b>Exchange</b><p class="mt-2 text-xs text-slate-600">ငွေလဲနှုန်းတွက်ရန်</p></button>
      </div>
    </section>

    <section id="voucherPage" class="page">
      <div class="rounded-[28px] bg-white p-5 shadow-sm ring-1 ring-slate-200">
        <p class="text-xs font-black uppercase text-teal-700">Voucher Lookup</p>
        <h1 class="mt-2 text-2xl font-black">ပြင်ဆင်မှုအခြေအနေ စစ်ဆေးရန်</h1>
        <div class="mt-5 grid gap-3">
          <input id="voucherInput" class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3" placeholder="ဥပမာ P9005">
          <button id="voucherBtn" class="rounded-2xl bg-teal-600 px-5 py-3 font-black text-white">Search</button>
        </div>
        <div id="voucherResult" class="mt-5"></div>
      </div>
    </section>

    <section id="solutionsPage" class="page">
      <div class="rounded-[28px] bg-white p-5 shadow-sm ring-1 ring-slate-200">
        <p class="text-xs font-black uppercase text-amber-700">Repair Solution</p>
        <h1 class="mt-2 text-2xl font-black">ဖုန်းပြင်နည်းနှင့် Error Solution များ</h1>
        <input id="solutionSearch" class="mt-5 w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3" placeholder="Search solutions">
      </div>
      <div id="solutionsGrid" class="mt-4 grid gap-3 sm:grid-cols-2 xl:grid-cols-3"></div>
    </section>

    <section id="productsPage" class="page">
      <div class="rounded-[28px] bg-white p-5 shadow-sm ring-1 ring-slate-200">
        <p class="text-xs font-black uppercase text-indigo-700">Digital Product</p>
        <h1 class="mt-2 text-2xl font-black">VPN, Game နှင့် Digital Service များ</h1>
        <p class="mt-3 text-sm text-slate-600">Backend ကတင်ထားသော product ပုံများကို အောက်မှာ ပြပါမယ်။</p>
      </div>
      <div id="productGrid" class="mt-4 grid gap-3 sm:grid-cols-2 xl:grid-cols-4"></div>
    </section>

    <section id="currencyPage" class="page">
      <div class="rounded-[28px] bg-white p-5 shadow-sm ring-1 ring-slate-200">
        <p class="text-xs font-black uppercase text-rose-700">Currency Exchange</p>
        <h1 class="mt-2 text-2xl font-black">ငွေလဲနှုန်းများ</h1>
        <button id="refreshCurrency" class="mt-5 rounded-2xl bg-slate-950 px-5 py-3 text-sm font-black text-white">Refresh Rate</button>
        <p id="currencyTime" class="mt-4 text-sm font-bold text-slate-500">Updated: --</p>
      </div>
      <div class="mt-4 rounded-[24px] bg-white p-4 shadow-sm ring-1 ring-slate-200">
        <h2 class="text-xl font-black">လဲချင်တဲ့ပမာဏ တွက်ရန်</h2>
        <div class="mt-4 grid gap-3">
          <input id="exchangeAmount" inputmode="decimal" class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 font-bold" placeholder="လဲချင်တဲ့ပမာဏ">
          <select id="exchangeCode" class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 font-bold"></select>
        </div>
        <div id="exchangeResult" class="mt-4 rounded-2xl bg-slate-50 p-4 text-sm font-bold text-slate-600">ပမာဏထည့်ပြီး ငွေကြေးအမျိုးအစားရွေးပါ။</div>
        <a id="exchangeTelegramBtn" class="mt-3 block rounded-2xl bg-teal-600 px-4 py-3 text-center text-sm font-black text-white opacity-50 pointer-events-none" href="https://t.me/Mylifemychoice68" target="_blank" rel="noreferrer">Telegram မှာ ပို့ရန်</a>
      </div>
      <div id="currencyList" class="mt-4 rounded-[24px] bg-white p-3 shadow-sm ring-1 ring-slate-200"></div>
    </section>

    <footer class="mt-5 rounded-[28px] bg-white p-5 text-sm text-slate-600 shadow-sm ring-1 ring-slate-200">
      <b class="text-slate-950">Mahar Shwe Mobile</b>
      <p class="mt-2 font-bold">ဆီဆိုင်မြို့နယ်၊ ရှမ်းပြည်တောင်ပိုင်း</p>
      <a class="mt-2 inline-block font-black text-teal-700" href="https://maps.app.goo.gl/zodJ9fgcc9W7qsFVA" target="_blank" rel="noreferrer">Google Map ကြည့်ရန်</a>
      <p class="mt-3">KBZ Pay: 09778394052</p>
      <p>KBZ Special: 34551107002743002</p>
      <p>True Money: 0944070246</p>
      <p>Krungthai Bank: 000-3-35 722-8</p>
    </footer>
  </main>

  <nav class="bottom fixed inset-x-0 bottom-0 z-50 border-t border-slate-200 bg-white/95 px-2 pt-2 shadow-xl backdrop-blur">
    <div class="mx-auto grid max-w-md grid-cols-5 gap-1 text-center text-[11px] font-black">
      <button class="nav rounded-2xl px-1 py-2" data-page="home">Home</button>
      <button class="nav rounded-2xl px-1 py-2" data-page="voucher">Voucher</button>
      <button class="nav rounded-2xl px-1 py-2" data-page="solutions">Solution</button>
      <button class="nav rounded-2xl px-1 py-2" data-page="products">Product</button>
      <button class="nav rounded-2xl px-1 py-2" data-page="currency">Rate</button>
    </div>
  </nav>

  <script>
    const API_URL = '/api';
    const pages = ['home', 'voucher', 'solutions', 'products', 'currency'];
    let currencyRates = [];
    const DEFAULT_SOLUTION_IMAGE = 'data:image/svg+xml;charset=UTF-8,' + encodeURIComponent('<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 450"><rect width="800" height="450" fill="#fef3c7"/><rect x="90" y="92" width="250" height="266" rx="34" fill="#0f172a"/><rect x="122" y="128" width="186" height="196" rx="18" fill="#fff"/><path d="M430 155h220M430 215h180M430 275h120" stroke="#0f172a" stroke-width="28" stroke-linecap="round"/><text x="400" y="374" font-family="Arial" font-size="38" font-weight="700" fill="#92400e">Repair Solution</text></svg>');
    const DEFAULT_PRODUCT_IMAGE = 'data:image/svg+xml;charset=UTF-8,' + encodeURIComponent('<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 450"><rect width="800" height="450" fill="#e0e7ff"/><rect x="90" y="112" width="220" height="220" rx="40" fill="#312e81"/><circle cx="200" cy="222" r="68" fill="#818cf8"/><path d="M420 150h230M420 220h190M420 290h145" stroke="#1e1b4b" stroke-width="30" stroke-linecap="round"/><text x="370" y="374" font-family="Arial" font-size="38" font-weight="700" fill="#312e81">Digital Product</text></svg>');
    const fallbackRepairs = [
      { voucher:'P9005', model:'Oppo A78 5G', owner:'Bo Lay', issue:'TL/Blackglass', shop:'Power 9 Mobile', status:'ပြင်ပြီး ✅' }
    ];
    const fallbackSolutions = [
      { id:1, title:'iPhone Battery Drain Fix', description:'Battery calibration, background app check နှင့် charging port စစ်ဆေးနည်း။', category:'Software', author:'Admin', date:'2026-05-16', likes:8 }
    ];
    const fallbackProducts = [
      { title:'Premium VPN', price:'3,000 Ks / month', type:'VPN', desc:'Fast server, privacy setup, Android support' },
      { title:'Game Top-up', price:'Ask price', type:'Game', desc:'Mobile Legends, PUBG, Free Fire and more' }
    ];
    function el(id){ return document.getElementById(id); }
    function escapeHtml(value){ return String(value || '').replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c])); }
    function imageInfo(item, type){
      const fields = ['image','photo','imageUrl','image_url','picture','thumbnail','cover'];
      for (const field of fields) if (item && item[field]) return { url:item[field], source:item.imageMapping || field };
      return { url:type === 'product' ? DEFAULT_PRODUCT_IMAGE : DEFAULT_SOLUTION_IMAGE, source:item && item.imageMapping ? item.imageMapping : 'placeholder' };
    }
    async function callApi(path){ const res = await fetch(API_URL + path); if(!res.ok) throw new Error('HTTP ' + res.status); return res.json(); }
    function showPage(page){
      pages.forEach(name => el(name + 'Page').classList.toggle('active', name === page));
      document.querySelectorAll('.nav').forEach(link => link.classList.toggle('active', link.dataset.page === page));
      history.replaceState(null, '', page === 'home' ? location.pathname : '#' + page);
      if(page === 'solutions') loadSolutions();
      if(page === 'products') renderProducts();
      if(page === 'currency') loadCurrency();
      window.scrollTo({top:0, behavior:'smooth'});
    }
    function resultCard(data){
      return '<div class="rounded-2xl border border-emerald-200 bg-emerald-50 p-4 text-sm text-emerald-950">' +
        '<p class="text-base font-black">Status: ' + escapeHtml(data.status || 'စောင့်ဆိုင်းနေဆဲ') + '</p>' +
        '<div class="mt-3 grid gap-2"><p><b>Voucher:</b> ' + escapeHtml(data.voucher || '-') + '</p><p><b>Model:</b> ' + escapeHtml(data.model || '-') + '</p><p><b>Customer:</b> ' + escapeHtml(data.customer || data.owner || '-') + '</p><p><b>Issue:</b> ' + escapeHtml(data.issue || '-') + '</p><p><b>Cost:</b> ' + (data.cost ? Number(data.cost).toLocaleString() + ' Ks' : 'Not set') + '</p><p><b>Shop:</b> ' + escapeHtml(data.shop || 'Mahar Shwe Mobile') + '</p></div></div>';
    }
    async function lookupVoucher(){
      const voucher = (el('voucherInput').value || '').trim().toUpperCase();
      if(!voucher){ el('voucherResult').innerHTML = '<div class="rounded-2xl border border-rose-200 bg-rose-50 p-4 text-sm font-black text-rose-700">Voucher နံပါတ် ထည့်ပါ။</div>'; return; }
      try { const data = await callApi('/voucher/' + encodeURIComponent(voucher)); el('voucherResult').innerHTML = data && data.found ? resultCard(data) : notFound(); }
      catch(e){ const demo = fallbackRepairs.find(x => x.voucher === voucher); el('voucherResult').innerHTML = demo ? resultCard(demo) : notFound(); }
    }
    function notFound(){ return '<div class="rounded-2xl border border-rose-200 bg-rose-50 p-4 text-sm font-black text-rose-700">Voucher မတွေ့ပါ။ နံပါတ်ကို ပြန်စစ်ပါ။</div>'; }
    async function loadSolutions(){
      const q = (el('solutionSearch').value || '').trim();
      let list = fallbackSolutions;
      try { const data = await callApi('/solutions' + (q ? '?q=' + encodeURIComponent(q) : '')); if(Array.isArray(data) && data.length) list = data; } catch(e) {}
      if(q){ const lower = q.toLowerCase(); list = list.filter(x => (x.title + ' ' + x.description + ' ' + x.category).toLowerCase().includes(lower)); }
      el('solutionsGrid').innerHTML = list.map(item => { const img = imageInfo(item, 'solution'); return '<article class="rounded-[24px] bg-white p-4 shadow-sm ring-1 ring-slate-200"><span class="rounded-full bg-amber-100 px-3 py-1 text-[11px] font-black text-amber-800">' + escapeHtml(item.category || 'Tips') + '</span><img src="' + escapeHtml(img.url) + '" alt="' + escapeHtml(item.title || 'Solution image') + '" class="mt-4 aspect-video w-full rounded-2xl object-cover ring-1 ring-slate-200"><div class="mt-3 rounded-xl bg-slate-50 px-3 py-2 text-[11px] font-black text-slate-500">Image Mapping: ' + escapeHtml(img.source) + '</div><h2 class="mt-4 text-lg font-black">' + escapeHtml(item.title) + '</h2><p class="mt-3 text-sm leading-7 text-slate-600">' + escapeHtml(item.description) + '</p><div class="mt-5 flex justify-between border-t border-slate-100 pt-4 text-xs font-black text-slate-500"><span>' + escapeHtml(item.author || 'Admin') + '</span><span>' + Number(item.likes || 0) + ' likes</span></div></article>'; }).join('');
    }
    async function renderProducts(){
      let list = fallbackProducts;
      try { const data = await callApi('/products'); if(Array.isArray(data) && data.length) list = data; } catch(e) {}
      el('productGrid').innerHTML = list.map(item => { const img = imageInfo(item, 'product'); const orderUrl = item.orderUrl || ('https://t.me/Mylifemychoice68?text=' + encodeURIComponent('Hello Mahar Shwe Mobile, I want to order ' + item.title + ' (' + item.price + ').')); return '<article class="rounded-[24px] bg-white p-4 shadow-sm ring-1 ring-slate-200"><span class="rounded-full bg-indigo-100 px-3 py-1 text-[11px] font-black text-indigo-800">' + escapeHtml(item.type || 'Digital') + '</span><img src="' + escapeHtml(img.url) + '" alt="' + escapeHtml(item.title || 'Product image') + '" class="mt-4 aspect-video w-full rounded-2xl object-cover ring-1 ring-slate-200"><div class="mt-3 rounded-xl bg-slate-50 px-3 py-2 text-[11px] font-black text-slate-500">Image Mapping: ' + escapeHtml(img.source) + '</div><h2 class="mt-4 text-lg font-black">' + escapeHtml(item.title) + '</h2><p class="mt-2 text-xl font-black text-indigo-700">' + escapeHtml(item.price) + '</p><p class="mt-3 text-sm leading-6 text-slate-600">' + escapeHtml(item.desc || item.description || '') + '</p><a class="mt-5 block rounded-2xl bg-slate-950 px-4 py-3 text-center text-sm font-black text-white" href="' + orderUrl + '" target="_blank" rel="noreferrer">Telegram မှာ Order တင်ရန်</a></article>'; }).join('');
    }
    async function loadCurrency(){
      let rates = [{code:'USD', rate:3520, name:'US Dollar', change:'+0.5%'},{code:'THB', rate:98.5, name:'Thai Baht', change:'-0.2%'},{code:'SGD', rate:2610, name:'Singapore Dollar', change:'+0.1%'}];
      try { const data = await callApi('/currency'); if(Array.isArray(data) && data.length) rates = data; } catch(e) {}
      currencyRates = rates.map(x => ({ code:String(x.code || '').toUpperCase(), name:x.name || 'Myanmar Kyat', rate:Number(x.rate), change:x.change || '0%' })).filter(x => x.code && Number.isFinite(x.rate));
      el('exchangeCode').innerHTML = currencyRates.map(x => '<option value="' + escapeHtml(x.code) + '">' + escapeHtml(x.code) + ' - ' + escapeHtml(x.name) + '</option>').join('');
      el('currencyTime').textContent = 'Updated: ' + new Date().toLocaleString();
      el('currencyList').innerHTML = currencyRates.map(x => '<div class="mb-3 flex items-center justify-between rounded-2xl border border-slate-200 bg-slate-50 p-4"><div><b>' + escapeHtml(x.code) + '</b><p class="text-xs text-slate-500">' + escapeHtml(x.name) + '</p></div><div class="text-right"><b>' + Number(x.rate).toLocaleString() + ' MMK</b><p class="text-xs text-slate-500">' + escapeHtml(x.change) + '</p></div></div>').join('');
      updateExchangeCalculator();
    }
    function updateExchangeCalculator(){
      const amount = Number(String(el('exchangeAmount').value || '').replace(/,/g,''));
      const code = el('exchangeCode').value;
      const rate = currencyRates.find(x => x.code === code);
      if(!rate || !Number.isFinite(amount) || amount <= 0){ el('exchangeResult').textContent = 'ပမာဏထည့်ပြီး ငွေကြေးအမျိုးအစားရွေးပါ။'; el('exchangeTelegramBtn').classList.add('opacity-50','pointer-events-none'); return; }
      const total = amount * rate.rate;
      el('exchangeResult').innerHTML = '<p class="text-xs font-black uppercase text-slate-500">ခန့်မှန်းတန်ဖိုး</p><p class="mt-1 text-2xl font-black text-slate-950">' + Math.round(total).toLocaleString() + ' MMK</p><p class="mt-2 text-xs text-slate-500">Rate: 1 ' + escapeHtml(rate.code) + ' = ' + Number(rate.rate).toLocaleString() + ' MMK</p>';
      const message = 'မင်္ဂလာပါ Mahar Shwe Mobile, ငွေလဲချင်ပါတယ်။\nCurrency: ' + rate.code + '\nAmount: ' + amount.toLocaleString() + ' ' + rate.code + '\nRate: ' + Number(rate.rate).toLocaleString() + ' MMK\nTotal: ' + Math.round(total).toLocaleString() + ' MMK';
      el('exchangeTelegramBtn').href = 'https://t.me/Mylifemychoice68?text=' + encodeURIComponent(message);
      el('exchangeTelegramBtn').classList.remove('opacity-50','pointer-events-none');
    }
    document.querySelectorAll('[data-page]').forEach(button => button.addEventListener('click', () => showPage(button.dataset.page)));
    el('voucherBtn').addEventListener('click', lookupVoucher);
    el('solutionSearch').addEventListener('input', () => { clearTimeout(window.solutionTimer); window.solutionTimer = setTimeout(loadSolutions, 250); });
    el('refreshCurrency').addEventListener('click', loadCurrency);
    el('exchangeAmount').addEventListener('input', updateExchangeCalculator);
    el('exchangeCode').addEventListener('change', updateExchangeCalculator);
    const initial = location.hash ? location.hash.slice(1) : 'home';
    showPage(pages.includes(initial) ? initial : 'home');
  </script>
</body>
</html>
